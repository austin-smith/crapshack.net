---
import Layout from '../layouts/Layout.astro';
import Dialog from '../components/ui/Dialog.astro';
import Dropdown from '../components/ui/Dropdown.astro';
import ScreenshotGallery from '../components/ui/ScreenshotGallery.astro';
import ToggleGroup from '../components/ui/ToggleGroup.astro';
import { computerSolitaireVariants as variants } from '../lib/computer-solitaire';
import { BookText, Package } from '@lucide/astro';

const computerSolitaireRelease = {
	releaseTag: 'v0.8.0',
	dmgAssetName: 'ComputerSolitaire-v0.8.0-arm64.dmg',
};
const repoUrl = 'https://github.com/austin-smith/ComputerSolitaire';
const releasesUrl = 'https://github.com/austin-smith/ComputerSolitaire/releases';
const directDownloadUrl = `https://github.com/austin-smith/ComputerSolitaire/releases/download/${computerSolitaireRelease.releaseTag}/${computerSolitaireRelease.dmgAssetName}`;
const iconUrl = '/images/computer-solitaire/computer-solitaire-icon.png';
const screenshots = [
	{
		id: 'ios',
		label: 'ios',
		src: '/images/computer-solitaire/screen-grabs/screen-grab-ios.png',
		alt: 'Computer Solitaire on iOS',
	},
	{
		id: 'macos',
		label: 'macos',
		src: '/images/computer-solitaire/screen-grabs/screen-grab-macos.png',
		alt: 'Computer Solitaire on macOS',
	},
];
---

<Layout
	title="crapshack (computer solitaire)"
	ogImage="/open-graph/computer-solitaire.png"
	noIndex={true}
>
	<section class="mx-auto max-w-3xl space-y-8 mt-10">
		<header class="flex items-center gap-4">
			<img src={iconUrl} alt="Computer Solitaire icon" width="96" height="96" class="h-24 w-24 shrink-0 object-contain drop-shadow-md" loading="lazy" />
			<div>
				<h1 class="text-3xl font-mono font-semibold bg-gradient-to-r from-[var(--color-brand)] to-white bg-clip-text text-transparent">Computer Solitaire</h1>
				<p class="text-white/90">A fully native Solitaire app for iOS, iPadOS, and macOS.</p>
			</div>
		</header>

		<div class="flex flex-wrap gap-2 sm:gap-3">
			<a
				href={repoUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center rounded-md bg-[var(--color-brand)] px-4 py-2 font-medium hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
			>
				<img src="/images/brands/github-black.svg" alt="" aria-hidden="true" class="mr-2 h-4 w-4" />
				<span>github</span>
			</a>
			<a
				href={releasesUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center rounded-md border border-white/20 px-4 py-2 font-medium text-[var(--color-text)] hover:text-[var(--color-brand)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
			>
				<Package width={16} height={16} stroke-width={2} class="mr-2" />
				<span>releases</span>
			</a>
			<a
				href={directDownloadUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center rounded-md border border-white/20 px-4 py-2 font-medium text-[var(--color-text)] hover:text-[var(--color-brand)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
			>
				<span aria-hidden="true" class="mr-2 h-4 w-4 shrink-0 icon-apple"></span>
				<span>macOS</span>
			</a>
		</div>

		<ScreenshotGallery
			name="computer-solitaire"
			screenshots={screenshots}
			dialogAriaLabel="Computer Solitaire screenshot dialog"
			toggleAriaLabel="Screenshot platform"
		/>

		<section class="space-y-3">
			<h2 class="text-2xl font-mono font-semibold text-[var(--color-text)]"># Features</h2>
			<ul class="list-disc pl-6 space-y-1 text-white/95">
				<li>Fully native apps for iOS, iPadOS, and macOS</li>
				<li>10 game variants, including Klondike, Spider, and FreeCell</li>
				<li>Solver-computed hints</li>
				<li>Game statistics for every variant</li>
				<li>Automatic game persistence and resume</li>
				<li>Customizable cards and table appearance</li>
				<li>Other things you enjoy</li>
			</ul>
		</section>

		<section class="space-y-4" aria-labelledby="computer-solitaire-variants-heading">
			<div class="flex flex-wrap items-center justify-between gap-2">
				<h2 id="computer-solitaire-variants-heading" class="text-2xl font-mono font-semibold text-[var(--color-text)]"># Game Variants</h2>
				<button
					id="computer-solitaire-guide-trigger"
					type="button"
					class="inline-flex items-center rounded-md border border-white/20 px-3 py-1.5 text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-brand)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
				>
					<BookText width={15} height={15} stroke-width={2} class="mr-2" />
					<span>guide</span>
				</button>
			</div>
			<ol class="overflow-hidden rounded-lg border border-white/10 bg-black/10 divide-y divide-white/10 shadow-lg">
				{variants.map((variant, index) => (
					<li class="relative grid grid-cols-[2rem_1fr] gap-x-3 px-4 py-3 transition-colors hover:bg-white/5 sm:grid-cols-[2rem_8.5rem_1fr] sm:items-baseline sm:gap-x-4">
						<span aria-hidden="true" class="font-mono text-xs tabular-nums text-white/35">
							{String(index + 1).padStart(2, '0')}
						</span>
						<h3>
							<button
								type="button"
								data-computer-solitaire-variant-trigger={variant.id}
								aria-label={`${variant.name} guide`}
								class="font-mono font-semibold text-[var(--color-text)] transition-colors hover:text-[var(--color-brand)] after:absolute after:inset-0 focus-visible:outline-none focus-visible:after:ring-2 focus-visible:after:ring-inset focus-visible:after:ring-[var(--color-brand)]/70"
							>
								{variant.name}
							</button>
						</h3>
						<p class="col-start-2 mt-1 text-sm leading-relaxed text-white/75 sm:col-start-3 sm:mt-0">{variant.description}</p>
					</li>
					))}
				</ol>
			</section>

			<Dialog id="computer-solitaire-guide-dialog" maxWidth="max-w-3xl" ariaLabel="Computer Solitaire guide dialog">
				<div class="space-y-5 text-white/95">
					<h2 class="pr-10 text-2xl font-mono font-semibold text-[var(--color-text)]"># Computer Solitaire Guide</h2>

					<Dropdown
						id="computer-solitaire-guide-variant"
						options={variants.map((variant) => ({ value: variant.id, label: variant.name }))}
						defaultValue="klondike"
						ariaLabel="Game"
					/>

					<div class="space-y-4 rounded-xl border border-white/10 bg-white/5 p-4 sm:p-5">
						<div class="flex justify-center sm:justify-start">
							<ToggleGroup
								name="computer-solitaire-guide-section"
								options={[
									{ value: 'rules', label: 'rules' },
									{ value: 'scoring', label: 'scoring' },
									{ value: 'terms', label: 'terms' },
								]}
								defaultValue="rules"
								ariaLabel="Computer Solitaire guide section"
							/>
						</div>

						{variants.map((variant) => (
							<>
								<section
									class="space-y-4"
									data-computer-solitaire-guide-panel="rules"
									data-computer-solitaire-guide-variant={variant.id}
									hidden={variant.id !== 'klondike'}
								>
									<div class="space-y-2">
										<h3 class="text-lg font-semibold text-[var(--color-text)]">Objective</h3>
										<p>{variant.objective}</p>
									</div>
									<div class="space-y-2">
										<h3 class="text-lg font-semibold text-[var(--color-text)]">Core Rules</h3>
										<ul class="list-disc space-y-1 pl-6">
											{variant.rules.map((rule) => <li>{rule}</li>)}
										</ul>
									</div>
								</section>

								<section
									class="space-y-4"
									data-computer-solitaire-guide-panel="scoring"
									data-computer-solitaire-guide-variant={variant.id}
									hidden
								>
									<div class="overflow-x-auto">
										<table class="w-full min-w-[26rem] border-collapse text-left text-sm">
											<thead>
												<tr class="border-b border-white/10">
													<th scope="col" class="pb-2 pr-5 font-semibold text-[var(--color-text)]">Move</th>
													<th scope="col" class="pb-2 text-right font-semibold text-[var(--color-text)]">Points</th>
												</tr>
											</thead>
											<tbody>
												{variant.scoring.map((row) => (
													<tr class="border-b border-white/[0.06] last:border-0">
														<td class="py-2 pr-5 align-top">
															<span>{row.move}</span>
															{row.note && <span class="mt-0.5 block text-xs text-white/55">{row.note}</span>}
														</td>
														<td class="py-2 text-right align-top font-mono tabular-nums">{row.points}</td>
													</tr>
												))}
											</tbody>
										</table>
									</div>
									<ul class="list-disc space-y-1 pl-6 text-sm text-white/70">
										{variant.scoringNotes.map((note) => <li>{note}</li>)}
									</ul>
								</section>

								<section
									data-computer-solitaire-guide-panel="terms"
									data-computer-solitaire-guide-variant={variant.id}
									hidden
								>
									<dl class="space-y-3">
										{variant.terms.map((term) => (
											<div>
												<dt class="font-semibold text-white">{term.term}</dt>
												<dd class="mt-0.5 text-sm text-white/75">{term.definition}</dd>
											</div>
										))}
									</dl>
								</section>
							</>
						))}
					</div>
				</div>
			</Dialog>
		</section>
</Layout>

<script>
	import { openDialog } from '../lib/ui/dialog';

	const computerSolitaireGuideTrigger = document.getElementById('computer-solitaire-guide-trigger') as HTMLButtonElement | null;
	const computerSolitaireGuideDialog = document.getElementById('computer-solitaire-guide-dialog') as HTMLElement | null;
	const computerSolitaireGuideVariantDropdown = document.getElementById('computer-solitaire-guide-variant');
	const computerSolitaireGuidePanels = document.querySelectorAll<HTMLElement>('[data-computer-solitaire-guide-panel]');

	let computerSolitaireGuideVariant = 'klondike';
	let computerSolitaireGuideSection = 'rules';

	function syncComputerSolitaireGuideToggles() {
		const checkedGuideInput = document.querySelector<HTMLInputElement>(
			'[data-toggle-group="computer-solitaire-guide-section"] input[type="radio"]:checked'
		);
		if (!checkedGuideInput) return;
		document.dispatchEvent(new CustomEvent('toggle-set-value', {
			detail: { name: 'computer-solitaire-guide-section', value: checkedGuideInput.value }
		}));
	}

	function openComputerSolitaireGuide(variantId?: string) {
		if (variantId) {
			document.dispatchEvent(new CustomEvent('dropdown-set-value', {
				detail: { id: 'computer-solitaire-guide-variant', value: variantId }
			}));
		}
		openDialog('computer-solitaire-guide-dialog');
		requestAnimationFrame(syncComputerSolitaireGuideToggles);
		computerSolitaireGuideDialog?.querySelector<HTMLElement>('[data-dialog-container]')?.addEventListener('transitionend', () => {
			syncComputerSolitaireGuideToggles();
		}, { once: true });
	}

	computerSolitaireGuideTrigger?.addEventListener('click', () => {
		openComputerSolitaireGuide();
	});

	document.querySelectorAll<HTMLButtonElement>('[data-computer-solitaire-variant-trigger]').forEach((trigger) => {
		trigger.addEventListener('click', () => {
			const variantId = trigger.dataset.computerSolitaireVariantTrigger;
			if (variantId) openComputerSolitaireGuide(variantId);
		});
	});

	function updateComputerSolitaireGuidePanels() {
		computerSolitaireGuidePanels.forEach((panel) => {
			panel.hidden =
				panel.dataset.computerSolitaireGuidePanel !== computerSolitaireGuideSection ||
				panel.dataset.computerSolitaireGuideVariant !== computerSolitaireGuideVariant;
		});
	}

	updateComputerSolitaireGuidePanels();

	computerSolitaireGuideVariantDropdown?.addEventListener('dropdown-change', ((event: CustomEvent<{ value: string }>) => {
		computerSolitaireGuideVariant = event.detail.value;
		updateComputerSolitaireGuidePanels();
	}) as EventListener);

	document.querySelector<HTMLElement>('[data-toggle-group="computer-solitaire-guide-section"]')
		?.addEventListener('toggle-change', ((event: CustomEvent<{ value: string }>) => {
			computerSolitaireGuideSection = event.detail.value;
			updateComputerSolitaireGuidePanels();
		}) as EventListener);
</script>
