---
import Layout from '../layouts/Layout.astro';
import Dialog from '../components/ui/Dialog.astro';
import ToggleGroup from '../components/ui/ToggleGroup.astro';
import { History, Library, MonitorPlay, Package, Users } from '@lucide/astro';

const repoUrl = 'https://github.com/austin-smith/PlexBar';
const releasesUrl = 'https://github.com/austin-smith/PlexBar/releases';
const appcastUrl = 'https://austin-smith.github.io/PlexBar/appcast.xml';
const iconUrl = '/images/plexbar/plexbar.png';
const screenshots = [
	{
		id: 'streams',
		label: 'streams',
		src: '/images/plexbar/screen-grabs/screen-grab-streams.png',
		alt: 'PlexBar active streams view',
	},
	{
		id: 'history',
		label: 'history',
		src: '/images/plexbar/screen-grabs/screen-grab-history.png',
		alt: 'PlexBar history view',
	},
	{
		id: 'users',
		label: 'users',
		src: '/images/plexbar/screen-grabs/screen-grab-users.png',
		alt: 'PlexBar users view',
	},
	{
		id: 'libraries',
		label: 'libraries',
		src: '/images/plexbar/screen-grabs/screen-grab-libraries.png',
		alt: 'PlexBar libraries view',
	},
];
const views = [
	{
		title: 'Streams',
		icon: MonitorPlay,
		body: 'Active playback and stream status',
	},
	{
		title: 'History',
		icon: History,
		body: 'Recent plays and top titles',
	},
	{
		title: 'Users',
		icon: Users,
		body: 'Viewer activity and recent watches',
	},
	{
		title: 'Libraries',
		icon: Library,
		body: 'Media libraries and recent additions',
	},
];
const features = [
	'Native macOS menu bar app',
	'Plex sign-in and server discovery',
	'Local, remote, and relay connection resolution',
	'Live view of active sessions with playback details',
	'Watch history, top titles, and user activity summaries',
	'Library overview with item counts and status dates'
];
---

<Layout
	title="crapshack (plexbar)"
	ogImage="/images/plexbar/plexbar.png"
	noIndex={true}
>
	<section class="mx-auto max-w-3xl space-y-8 mt-10">
		<header class="flex items-center gap-4">
			<img src={iconUrl} alt="PlexBar icon" width="96" height="96" class="rounded-2xl drop-shadow-md" loading="lazy" />
			<div>
				<h1 class="text-3xl font-mono font-semibold bg-gradient-to-r from-[var(--color-brand)] to-white bg-clip-text text-transparent">PlexBar</h1>
				<p class="text-white/90">A lightweight macOS menu bar app for Plex server telemetry.</p>
			</div>
		</header>

		<div class="flex flex-wrap gap-3">
			<a
				href={repoUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center rounded-md bg-[var(--color-brand)] px-4 py-2 font-medium hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
			>
				<img src="/images/brands/github-black.svg" alt="" aria-hidden="true" class="mr-2 h-4 w-4" />
				<span>github</span>
			</a>
			<a
				href={releasesUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center rounded-md border border-white/20 px-4 py-2 font-medium text-[var(--color-text)] hover:text-[var(--color-brand)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
			>
				<Package width={16} height={16} stroke-width={2} class="mr-2" />
				<span>releases</span>
			</a>
			<a
				id="plexbar-download-link"
				href={releasesUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center rounded-md border border-white/20 px-4 py-2 font-medium text-[var(--color-text)] hover:text-[var(--color-brand)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]/70"
				data-appcast-url={appcastUrl}
			>
				<span aria-hidden="true" class="mr-2 h-4 w-4 shrink-0 icon-apple"></span>
				<span>download for macOS</span>
			</a>
		</div>

		<div class="screenshots flex flex-wrap items-start gap-4">
			{screenshots.map((screenshot) => (
				<button
					type="button"
					class="screenshot-trigger group relative rounded-xl overflow-hidden border border-white/10 shadow-lg h-[13rem] sm:h-[18rem] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]"
					data-screenshot-trigger
					data-id={screenshot.id}
				>
					<img src={screenshot.src} alt={screenshot.alt} class="h-full w-auto opacity-0 transition-all duration-300 group-hover:scale-[1.02]" data-screenshot loading="lazy" />
				</button>
			))}
		</div>

		<Dialog id="screenshot-dialog" maxWidth="max-w-4xl" ariaLabel="PlexBar screenshot dialog">
			<img id="screenshot-dialog-img" src="" alt="" class="w-full max-h-[75vh] object-contain rounded-lg" />
			<div class="flex justify-center">
				<ToggleGroup
					name="screenshot-view"
					options={screenshots.map(({ id, label }) => ({ value: id, label }))}
					defaultValue="streams"
					ariaLabel="Screenshot view"
				/>
			</div>
		</Dialog>

		<section class="space-y-3">
			<h2 class="text-2xl font-mono font-semibold text-[var(--color-text)]"># Views</h2>
			<div class="grid gap-3 sm:grid-cols-2">
				{views.map((view) => (
					<article class="rounded-lg border border-white/10 bg-white/[0.04] p-4 shadow-lg">
						<h3 class="flex items-center gap-2 font-mono font-semibold text-[var(--color-text)]">
							<view.icon width={18} height={18} stroke-width={2} class="text-[var(--color-brand)]" />
							<span>{view.title}</span>
						</h3>
						<p class="mt-2 text-sm text-white/80">{view.body}</p>
					</article>
				))}
			</div>
		</section>

		<section class="space-y-3">
			<h2 class="text-2xl font-mono font-semibold text-[var(--color-text)]"># Features</h2>
			<ul class="list-disc pl-6 space-y-1 text-white/95">
				{features.map((feature) => (
					<li>{feature}</li>
				))}
			</ul>
		</section>
	</section>
</Layout>

<script>
	import { fetchLatestAppcastRelease } from '../lib/appcast';
	import { openDialog } from '../lib/ui/dialog';

	const downloadLink = document.getElementById('plexbar-download-link') as HTMLAnchorElement | null;
	const appcastUrl = downloadLink?.dataset.appcastUrl;

	if (downloadLink && appcastUrl) {
		fetchLatestAppcastRelease(appcastUrl)
			.then((release) => {
				downloadLink.href = release.downloadUrl;
			});
	}

	const screenshots = document.querySelectorAll<HTMLImageElement>('[data-screenshot]');
	screenshots.forEach((img, i) => {
		const fadeIn = () => {
			setTimeout(() => {
				img.classList.remove('opacity-0');
				img.classList.add('opacity-100');
			}, i * 100);
		};
		if (img.complete) {
			fadeIn();
		} else {
			img.addEventListener('load', fadeIn, { once: true });
		}
	});

	const screenshotTriggers = document.querySelectorAll<HTMLButtonElement>('[data-screenshot-trigger]');
	const dialogImg = document.getElementById('screenshot-dialog-img') as HTMLImageElement | null;
	const toggleGroup = document.querySelector<HTMLElement>('[data-toggle-group="screenshot-view"]');

	const screenshotSources: Record<string, { src: string; alt: string }> = {
		streams: { src: '/images/plexbar/screen-grabs/screen-grab-streams.png', alt: 'PlexBar active streams' },
		history: { src: '/images/plexbar/screen-grabs/screen-grab-history.png', alt: 'PlexBar history' },
		users: { src: '/images/plexbar/screen-grabs/screen-grab-users.png', alt: 'PlexBar users' },
		libraries: { src: '/images/plexbar/screen-grabs/screen-grab-libraries.png', alt: 'PlexBar libraries' },
	};

	function setScreenshot(view: string) {
		if (!dialogImg) return;
		const source = screenshotSources[view];
		if (source) {
			dialogImg.src = source.src;
			dialogImg.alt = source.alt;
		}
	}

	screenshotTriggers.forEach((trigger) => {
		trigger.addEventListener('click', () => {
			const id = trigger.dataset.id;
			if (id) {
				setScreenshot(id);
				document.dispatchEvent(new CustomEvent('toggle-set-value', {
					detail: { name: 'screenshot-view', value: id }
				}));
				openDialog('screenshot-dialog');
			}
		});
	});

	toggleGroup?.addEventListener('toggle-change', ((e: CustomEvent<{ value: string }>) => {
		setScreenshot(e.detail.value);
	}) as EventListener);
</script>
